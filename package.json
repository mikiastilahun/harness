{
  "name": "harness",
  "description": "AI harness for engineering teams",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun turbo run dev --parallel",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun turbo run build",
    "typecheck": "bun turbo run typecheck",
    "lint": "oxlint",
    "format": "prettier --write ."
  },
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "@tsconfig/bun": "1.0.9",
      "@types/bun": "1.3.13",
      "@types/node": "24.12.2",
      "typescript": "5.8.2",
      "ai": "6.0.185",
      "@ai-sdk/google-vertex": "4.0.131",
      "@ai-sdk/svelte": "4.0.185",
      "zod": "4.1.8",
      "effect": "4.0.0-beta.65",
      "@effect/platform": "0.94.0",
      "@effect/platform-node": "4.0.0-beta.65",
      "hono": "4.10.7",
      "hono-openapi": "1.1.2",
      "@hono/zod-validator": "0.4.2",
      "tailwindcss": "4.1.11",
      "@tailwindcss/vite": "4.1.11",
      "vite": "7.1.4",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "shiki": "3.20.0",
      "dompurify": "3.3.1"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "oxlint": "1.60.0",
    "prettier": "3.6.2",
    "turbo": "2.8.13",
    "typescript": "catalog:"
  }
}

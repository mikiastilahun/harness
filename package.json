{
  "name": "harness",
  "description": "AI harness for engineering teams",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @harness/api dev",
    "dev:web": "pnpm --filter @harness/web dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint",
    "format": "prettier --write .",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "sandbox:up": "./infra/kata/start.sh",
    "sandbox:down": "colima stop harness",
    "db:generate": "pnpm --filter @harness/api db:generate",
    "db:migrate": "pnpm --filter @harness/api db:migrate",
    "db:push": "pnpm --filter @harness/api db:push",
    "db:studio": "pnpm --filter @harness/api db:studio"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "oxlint": "1.60.0",
    "prettier": "3.6.2",
    "turbo": "2.8.13",
    "typescript": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}

# Vertex AI — REQUIRED.
# Auth via ADC: run `gcloud auth application-default login` first.
GOOGLE_VERTEX_PROJECT=qa1-us-central1-vpc-63b3e2
# Region. Use 'global' to access the Gemini 3 preview models.
GOOGLE_VERTEX_LOCATION=global

# Kata sandbox cluster.
# KATA_CONTEXT is the kubeconfig context name; matches whatever
# colima profile created it (default colima profile is 'harness' →
# context 'colima-harness').
KATA_CONTEXT=colima-harness
KATA_NAMESPACE=harness-sandboxes
KATA_RUNTIME_CLASS=kata-clh
SANDBOX_IMAGE=harness-sandbox:1
SANDBOX_IMAGE_PULL_POLICY=IfNotPresent

# api server
API_PORT=8787
API_URL=http://localhost:8787
WEB_URL=http://localhost:5173

# postgres (matches infra/docker-compose.yml)
DATABASE_URL=postgres://harness:harness@localhost:5432/harness

# better-auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-bytes
BETTER_AUTH_URL=http://localhost:8787

# Google OAuth (Google Cloud Console → Credentials → OAuth client ID, web type).
# Authorized redirect URI: ${BETTER_AUTH_URL}/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# web — public env, read in the browser
PUBLIC_API_URL=http://localhost:8787

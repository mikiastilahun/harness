# Vertex AI (Gemini) — REQUIRED.
# Auth via gcloud Application Default Credentials:
#   gcloud auth application-default login
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
# Use 'global' to access the Gemini 3 preview models, or a region like
# 'us-central1' for 2.x models.
GOOGLE_VERTEX_LOCATION=global

# Sandbox cluster.
# Provider talks to the agent-sandbox controller (installed via ConfigSync
# from infrastructure/acm/config-root/qa1-us-central1/agent-sandbox/).
#  - qa1 GKE (default) → gke_qa1-us-central1-vpc-63b3e2_us-central1_qa1-us-central1-services
#  - local kind        → kind-harness-agent-sandbox    (./infra/agent-sandbox/setup.sh)
SANDBOX_CONTEXT=gke_qa1-us-central1-vpc-63b3e2_us-central1_qa1-us-central1-services
SANDBOX_NAMESPACE=harness-sandboxes
# Optional RuntimeClass for sandbox pods (e.g. gvisor) when the cluster has
# one installed. Leave unset for stock container isolation.
# SANDBOX_RUNTIME_CLASS=gvisor
SANDBOX_IMAGE=us-docker.pkg.dev/mgmt-us-central1-vpc-a2cc50/apps/harness-sandbox:1
SANDBOX_IMAGE_PULL_POLICY=IfNotPresent

# Servers
API_PORT=8787
API_URL=http://localhost:8787
WEB_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8787
